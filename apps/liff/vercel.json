{
  "git": { "deploymentEnabled": { "dev": false } },
  "buildCommand": "nuxt generate",
  "outputDirectory": ".output/public",
  "devCommand": "nuxt dev",
  "installCommand": "npm install --no-package-lock",
  "framework": "nuxtjs",
  "rewrites": [
    { "source": "/admin/:path*", "destination": "https://sido-admin-stism.vercel.app/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
