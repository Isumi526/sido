# LINE LIFFアプリID（LINE Developersで発行）
NUXT_PUBLIC_LIFF_ID=your-liff-id-here

# GAS WebhookのデプロイURL
NUXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOY_ID/exec

# アプリ環境（development / production）
NUXT_PUBLIC_APP_ENV=development
